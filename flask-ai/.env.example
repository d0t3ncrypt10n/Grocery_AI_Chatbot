# ─── Gemini API ──────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# ─── Node.js Backend URL ────────────────────────────────────────
NODE_BACKEND_URL=http://localhost:4000

# ─── Flask Configuration ────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=true
