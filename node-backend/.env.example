# ─── Database Configuration ─────────────────────────────────────
# Use "sqlite" for local development, "postgres" for production
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite

# PostgreSQL configuration (uncomment for production)
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=grocery_ai
# DB_USER=postgres
# DB_PASSWORD=your_password

# ─── Server Configuration ──────────────────────────────────────
PORT=4000

# ─── Flask AI Service URL ──────────────────────────────────────
FLASK_AI_URL=http://localhost:5000
